generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Store {
  id          String   @id @default(cuid())
  storeId     String   @unique // Tiendanube store ID
  storeName   String?
  accessToken String
  createdAt   DateTime @default(now())
  claims      Claim[]
}

model Claim {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  orderNumber String
  type        String   // "reclamo", "cambio", "no_recibido"
  description String?
  photoUrl    String?
  status      String   @default("pendiente") // "pendiente", "aprobado", "rechazado"
  adminNotes  String?
  customerName  String?
  customerEmail String?
  customerPhone String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id       String @id @default(cuid())
  email    String @unique
  password String
}
