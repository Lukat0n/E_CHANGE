generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id          String   @id @default(cuid())
  storeId     String   @unique
  storeName   String?
  accessToken String
  createdAt   DateTime @default(now())
  claims      Claim[]
}

model Claim {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  orderNumber   String
  type          String
  description   String?
  photoUrl      String?
  status        String   @default("pendiente")
  adminNotes    String?
  customerName  String?
  customerEmail String?
  customerPhone String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminUser {
  id       String @id @default(cuid())
  email    String @unique
  password String
}
