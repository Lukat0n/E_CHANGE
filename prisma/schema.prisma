generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id          String   @id @default(cuid())
  storeId     String   @unique
  storeName   String?
  accessToken String
  createdAt   DateTime @default(now())
  claims      Claim[]
}

model Claim {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  orderNumber   String
  type          String
  description   String?
  photoUrl      String?
  status        String   @default("pendiente")
  adminNotes    String?
  customerName  String?
  customerEmail String?
  customerPhone String?
  // Shipping address for cambio claims
  shippingAddress       String?
  shippingNumber        String?
  shippingFloor         String?
  shippingNeighborhood  String?
  shippingCity          String?
  shippingProvince      String?
  shippingZipcode       String?
  shippingPhone         String?
  shippingRecipientName     String?
  shippingRecipientLastName String?
  // Shipping method (selected via Envío Nube storefront calculator)
  shippingMode         String?   // "domicilio" | "sucursal" | "presencial"
  shippingMethodCode   String?
  shippingMethodName   String?
  shippingCost         Float?
  // Mercado Pago payment tracking
  paymentStatus        String?   // null | "pending" | "approved" | "rejected" | "cancelled"
  paymentId            String?   // MP payment id once paid
  paymentAmount        Float?    // Total charged via MP (already includes 6% surcharge)
  mpPreferenceId       String?
  mpInitPoint          String?   // Checkout URL
  // WhatsApp notification tracking
  whatsappStatus       String?   // null | "sent" | "failed"
  whatsappError        String?   // last error message if failed
  whatsappSentAt       DateTime?
  // Robot-created shipment tracking
  shipmentTrackingCode String?   // ej. HC431755210AR (Correo Argentino)
  shipmentTrackingUrl  String?   // URL pública para que el cliente siga el envío
  shipmentRobotUrl     String?   // URL del envío en el admin de Tiendanube
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminUser {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

// Cache de cotizaciones del bot (Envío Nube admin). Se usa cuando la storefront
// devuelve $0 por promo de envío gratis y queremos el precio real del merchant.
// TTL ~24h: pasado ese tiempo se re-cotiza al bot.
model CarrierQuote {
  id          String   @id @default(cuid())
  storeId     String   // FK al Store.storeId (no relación porque el storeId del store es único en Store)
  zipcode     String
  carrierKey  String   // nombre normalizado (ej. "correo argentino clásico a domicilio")
  price       Float
  fetchedAt   DateTime @default(now())

  @@unique([storeId, zipcode, carrierKey])
  @@index([storeId, zipcode])
}
